{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "CheckDataModel",
  "description": "Data model for check documents extracted from document analysis",
  "type": "object",
  "properties": {
    "accountNumber": {
      "type": ["string", "null"],
      "description": "Account number associated with the check"
    },
    "checkNumber": {
      "type": ["integer", "null"],
      "description": "Check number"
    },
    "to": {
      "type": ["string", "null"],
      "description": "Payee name"
    },
    "description": {
      "type": ["string", "null"],
      "description": "Check description"
    },
    "date": {
      "type": ["string", "null"],
      "description": "Check date"
    },
    "amount": {
      "type": ["number", "null"],
      "description": "Check amount"
    },
    "checkEntries": {
      "$ref": "#/definitions/CheckEntriesTable",
      "description": "Nested check entries for composite checks"
    },
    "batesStamp": {
      "type": ["string", "null"],
      "description": "Bates stamp identifier for the check"
    },
    "pageMetadata": {
      "$ref": "#/definitions/ClassifiedPdfMetadata",
      "description": "PDF metadata for the check"
    }
  },
  "required": ["pageMetadata"],
  "definitions": {
    "ClassifiedPdfMetadata": {
      "type": "object",
      "properties": {
        "filename": {
          "type": "string",
          "description": "Name of the PDF file"
        },
        "pages": {
          "type": "array",
          "items": {
            "type": "integer"
          },
          "description": "Set of page numbers included"
        },
        "classification": {
          "type": "string",
          "description": "Document classification (e.g., check type)"
        }
      },
      "required": ["filename", "pages", "classification"]
    },
    "CheckEntriesTable": {
      "type": "object",
      "properties": {
        "images": {
          "type": "array",
          "items": {
            "$ref": "#/definitions/CheckEntriesTableRow"
          },
          "description": "List of check entry rows"
        }
      },
      "required": ["images"]
    },
    "CheckEntriesTableRow": {
      "type": "object",
      "properties": {
        "date": {
          "type": ["string", "null"],
          "description": "Check date"
        },
        "checkNumber": {
          "type": ["integer", "null"],
          "description": "Check number"
        },
        "to": {
          "type": ["string", "null"],
          "description": "Payee name"
        },
        "description": {
          "type": ["string", "null"],
          "description": "Check description"
        },
        "amount": {
          "type": ["number", "null"],
          "description": "Check amount"
        },
        "accountNumber": {
          "type": ["string", "null"],
          "description": "Account number"
        },
        "page": {
          "type": "integer",
          "description": "Page number"
        }
      },
      "required": ["page"]
    }
  }
} 