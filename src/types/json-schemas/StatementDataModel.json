{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "StatementDataModel",
  "description": "Raw data model extracted from document analysis for bank statements",
  "type": "object",
  "properties": {
    "date": {
      "type": ["string", "null"],
      "description": "Statement date in string format"
    },
    "accountNumber": {
      "type": ["string", "null"],
      "description": "Account number for this statement"
    },
    "beginningBalance": {
      "type": ["number", "null"],
      "description": "Beginning balance for the statement period"
    },
    "endingBalance": {
      "type": ["number", "null"],
      "description": "Ending balance for the statement period"
    },
    "feesCharged": {
      "type": ["number", "null"],
      "description": "Fees charged during the statement period"
    },
    "interestCharged": {
      "type": ["number", "null"],
      "description": "Interest charged during the statement period"
    },
    "summaryOfAccountsTable": {
      "$ref": "#/definitions/SummaryOfAccountsTable",
      "description": "Summary of accounts table (for multi-account statements)"
    },
    "transactionTableDepositWithdrawal": {
      "$ref": "#/definitions/TransactionTableDepositWithdrawal",
      "description": "Transaction table with deposit/withdrawal format"
    },
    "transactionTableAmount": {
      "$ref": "#/definitions/TransactionTableAmount",
      "description": "Transaction table with amount format"
    },
    "transactionTableCreditsCharges": {
      "$ref": "#/definitions/TransactionTableCreditsCharges",
      "description": "Transaction table with credits/charges format"
    },
    "transactionTableDebits": {
      "$ref": "#/definitions/TransactionTableDebits",
      "description": "Transaction table with debits format"
    },
    "transactionTableCredits": {
      "$ref": "#/definitions/TransactionTableCredits",
      "description": "Transaction table with credits format"
    },
    "transactionTableChecks": {
      "$ref": "#/definitions/TransactionTableChecks",
      "description": "Transaction table with checks format"
    },
    "batesStamps": {
      "$ref": "#/definitions/BatesStampTable",
      "description": "Bates stamps table"
    },
    "pageMetadata": {
      "$ref": "#/definitions/ClassifiedPdfMetadata",
      "description": "PDF metadata including filename, pages, and classification"
    },
    "manualRecordsTable": {
      "$ref": "#/definitions/ManualRecordTable",
      "description": "Manually entered records table"
    }
  },
  "required": ["pageMetadata"],
  "definitions": {
    "ClassifiedPdfMetadata": {
      "type": "object",
      "properties": {
        "filename": {
          "type": "string",
          "description": "Name of the PDF file"
        },
        "pages": {
          "type": "array",
          "items": {
            "type": "integer"
          },
          "description": "Set of page numbers included"
        },
        "classification": {
          "type": "string",
          "description": "Document classification (e.g., bank type)"
        }
      },
      "required": ["filename", "pages", "classification"]
    },
    "SummaryOfAccountsTable": {
      "type": "object",
      "properties": {
        "records": {
          "type": "array",
          "items": {
            "$ref": "#/definitions/SummaryOfAccountsTableRecord"
          },
          "description": "List of account summary records"
        }
      },
      "required": ["records"]
    },
    "SummaryOfAccountsTableRecord": {
      "type": "object",
      "properties": {
        "accountNumber": {
          "type": ["string", "null"],
          "description": "Account number"
        },
        "beginningBalance": {
          "type": ["number", "null"],
          "description": "Beginning balance for this account"
        },
        "endingBalance": {
          "type": ["number", "null"],
          "description": "Ending balance for this account"
        }
      }
    },
    "TransactionTableDepositWithdrawal": {
      "type": "object",
      "properties": {
        "records": {
          "type": "array",
          "items": {
            "$ref": "#/definitions/TransactionTableDepositWithdrawalRecord"
          },
          "description": "List of deposit/withdrawal transaction records"
        }
      },
      "required": ["records"]
    },
    "TransactionTableDepositWithdrawalRecord": {
      "type": "object",
      "properties": {
        "date": {
          "type": ["string", "null"],
          "description": "Transaction date"
        },
        "checkNumber": {
          "type": ["integer", "null"],
          "description": "Check number, if applicable"
        },
        "description": {
          "type": ["string", "null"],
          "description": "Transaction description"
        },
        "depositAmount": {
          "type": ["number", "null"],
          "description": "Deposit amount"
        },
        "withdrawalAmount": {
          "type": ["number", "null"],
          "description": "Withdrawal amount"
        },
        "page": {
          "type": "integer",
          "description": "Page number"
        }
      },
      "required": ["page"]
    },
    "TransactionTableAmount": {
      "type": "object",
      "properties": {
        "records": {
          "type": "array",
          "items": {
            "$ref": "#/definitions/TransactionTableAmountRecord"
          },
          "description": "List of amount-based transaction records"
        }
      },
      "required": ["records"]
    },
    "TransactionTableAmountRecord": {
      "type": "object",
      "properties": {
        "date": {
          "type": ["string", "null"],
          "description": "Transaction date"
        },
        "description": {
          "type": ["string", "null"],
          "description": "Transaction description"
        },
        "amount": {
          "type": ["number", "null"],
          "description": "Transaction amount"
        },
        "page": {
          "type": "integer",
          "description": "Page number"
        }
      },
      "required": ["page"]
    },
    "TransactionTableCreditsCharges": {
      "type": "object",
      "properties": {
        "records": {
          "type": "array",
          "items": {
            "$ref": "#/definitions/TransactionTableCreditsChargesRecord"
          },
          "description": "List of credits/charges transaction records"
        }
      },
      "required": ["records"]
    },
    "TransactionTableCreditsChargesRecord": {
      "type": "object",
      "properties": {
        "date": {
          "type": ["string", "null"],
          "description": "Transaction date"
        },
        "description": {
          "type": ["string", "null"],
          "description": "Transaction description"
        },
        "credits": {
          "type": ["number", "null"],
          "description": "Credits amount"
        },
        "charges": {
          "type": ["number", "null"],
          "description": "Charges amount"
        },
        "page": {
          "type": "integer",
          "description": "Page number"
        }
      },
      "required": ["page"]
    },
    "TransactionTableDebits": {
      "type": "object",
      "properties": {
        "records": {
          "type": "array",
          "items": {
            "$ref": "#/definitions/TransactionTableDebitsRecord"
          },
          "description": "List of debits transaction records"
        }
      },
      "required": ["records"]
    },
    "TransactionTableDebitsRecord": {
      "type": "object",
      "properties": {
        "date": {
          "type": ["string", "null"],
          "description": "Transaction date"
        },
        "description": {
          "type": ["string", "null"],
          "description": "Transaction description"
        },
        "subtractions": {
          "type": ["number", "null"],
          "description": "Subtractions amount"
        },
        "page": {
          "type": "integer",
          "description": "Page number"
        }
      },
      "required": ["page"]
    },
    "TransactionTableCredits": {
      "type": "object",
      "properties": {
        "records": {
          "type": "array",
          "items": {
            "$ref": "#/definitions/TransactionTableCreditsRecord"
          },
          "description": "List of credits transaction records"
        }
      },
      "required": ["records"]
    },
    "TransactionTableCreditsRecord": {
      "type": "object",
      "properties": {
        "date": {
          "type": ["string", "null"],
          "description": "Transaction date"
        },
        "description": {
          "type": ["string", "null"],
          "description": "Transaction description"
        },
        "additions": {
          "type": ["number", "null"],
          "description": "Additions amount"
        },
        "page": {
          "type": "integer",
          "description": "Page number"
        }
      },
      "required": ["page"]
    },
    "TransactionTableChecks": {
      "type": "object",
      "properties": {
        "records": {
          "type": "array",
          "items": {
            "$ref": "#/definitions/TransactionTableChecksRecord"
          },
          "description": "List of checks transaction records"
        }
      },
      "required": ["records"]
    },
    "TransactionTableChecksRecord": {
      "type": "object",
      "properties": {
        "date": {
          "type": ["string", "null"],
          "description": "Check date"
        },
        "number": {
          "type": ["integer", "null"],
          "description": "Check number"
        },
        "amount": {
          "type": ["number", "null"],
          "description": "Check amount"
        },
        "page": {
          "type": "integer",
          "description": "Page number"
        }
      },
      "required": ["page"]
    },
    "BatesStampTable": {
      "type": "object",
      "properties": {
        "batesStamps": {
          "type": "array",
          "items": {
            "$ref": "#/definitions/BatesStampTableRow"
          },
          "description": "List of bates stamp rows"
        }
      },
      "required": ["batesStamps"]
    },
    "BatesStampTableRow": {
      "type": "object",
      "properties": {
        "val": {
          "type": "string",
          "description": "Bates stamp value"
        },
        "page": {
          "type": "integer",
          "description": "Page number"
        }
      },
      "required": ["val", "page"]
    },
    "ManualRecordTable": {
      "type": "object",
      "properties": {
        "records": {
          "type": "array",
          "items": {
            "$ref": "#/definitions/ManualRecord"
          },
          "description": "List of manually entered records"
        }
      },
      "required": ["records"]
    },
    "ManualRecord": {
      "type": "object",
      "properties": {
        "id": {
          "type": ["string", "null"],
          "description": "Record identifier"
        },
        "date": {
          "type": ["string", "null"],
          "description": "Transaction date"
        },
        "description": {
          "type": ["string", "null"],
          "description": "Transaction description"
        },
        "amount": {
          "type": ["number", "null"],
          "description": "Transaction amount"
        },
        "checkNumber": {
          "type": ["integer", "null"],
          "description": "Check number, if applicable"
        },
        "checkPdfMetadata": {
          "$ref": "#/definitions/ClassifiedPdfMetadata",
          "description": "PDF metadata for associated check"
        },
        "page": {
          "type": "integer",
          "description": "Page number"
        }
      },
      "required": ["page"]
    }
  }
} 